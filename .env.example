# LLM Wiki — 配置文件
# 复制此文件为 .env 并填入你的 API Key

# ---- 大模型（复杂任务：矛盾分析、综述） ----
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o

# ---- 小模型（轻量任务：摘要、实体提取） ----
# 如果不设，默认复用大模型的 key 和 base
# LLM_SMALL_API_KEY=sk-your-key-here
# LLM_SMALL_MODEL=gpt-4o-mini

# ---- 路径（可选） ----
# WIKI_PATH=./wiki
# RAW_PATH=./raw
# SCHEMA_PATH=./CLAUDE.md
